# Programa-Python

def calcular_precio_final(producto, categoria_objetivo, umbral, descuento=0.15):
   
    nombre, categoria, precio_base = producto
    if categoria == categoria_objetivo and precio_base > umbral:
        return round(precio_base * (1 - descuento), 2)
    return round(precio_base, 2)


def main():
    # Matriz de productos: [Nombre, Categoria, PrecioBase]
    productos = [
        ["Hamburguesa", "principal", 8],
        ["Ensalada", "entrada", 6],
        ["Caldo de Pollo", "entrada", 4],
        ["Filete de Salmón", "principal", 15],
        ["Postre de Fresa", "postre", 5],
        ["Helado Casero", "postre", 3],
    ]

    categoria_objetivo = "principal"
    umbral = 10.00
    descuento = 0.15

    print("Producto             | Categoría | Precio base | Precio final")
    print("-" * 61)
    for p in productos:
        precio_base = p[2]
        precio_final = calcular_precio_final(p, categoria_objetivo, umbral, descuento)
        print(f"{p[0]:<20} | {p[1]:<9} | ${precio_base:6.2f}     | ${precio_final:6.2f}")

if __name__ == "__main__":
 main()
